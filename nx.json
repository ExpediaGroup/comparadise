{
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": { "targetName": "typecheck" },
        "build": { "targetName": "build" }
      }
    }
  ],
  "parallel": 5,
  "targetDefaults": {
    "build": {
      "cache": true
    }
  },
  "affected": {
    "defaultBase": "main"
  },
  "analytics": false
}
